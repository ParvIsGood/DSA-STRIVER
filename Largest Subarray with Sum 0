#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int maxLength(vector<int>& arr) {
        int n = arr.size();
        
        int sum = 0;          // prefix sum
        int ml = 0;           // max length
        int l = 0;            // current length
        
        unordered_map<int, int> mpp; // prefix sum -> first index

        for (int i = 0; i < n; i++) {
            sum += arr[i];

            // Case 1: subarray from 0 to i
            if (sum == 0) {
                l = i + 1;
                ml = max(ml, l);
            }

            // Case 2: prefix sum seen before
            if (mpp.find(sum) != mpp.end()) {
                l = i - mpp[sum];
                ml = max(ml, l);
            } 
            // Store first occurrence of prefix sum
            else {
                mpp[sum] = i;
            }
        }

        return ml;
    }
};
